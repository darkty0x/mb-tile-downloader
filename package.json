{
  "name": "mapbox-downloader",
  "version": "1.0.0",
  "description": "Cross-platform production tile downloader with row-level resume and provider configs.",
  "main": "downloader.js",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "download": "node downloader.js",
    "validate": "node downloader.js --validate",
    "download:mapbox-pbf": "node downloader.js configs/mapbox-pbf.config.json",
    "download:esri-satellite": "node downloader.js configs/esri-satellite.config.json",
    "download:mapbox-satellite": "node downloader.js configs/mapbox-satellite.config.json",
    "download:mapbox-dem": "node downloader.js configs/mapbox-dem.config.json",
    "split": "node downloader.js split",
    "zip": "node zip-maker.js",
    "make-directories": "node directory-maker.js",
    "download:mapbox-pbf-splits": "node downloader.js configs/mapbox-pbf-cig.config.json configs/mapbox-pbf-cmi.config.json configs/mapbox-pbf-kuh.config.json configs/mapbox-pbf-kyj.config.json configs/mapbox-pbf-mcs.config.json configs/mapbox-pbf-rhc.config.json",
    "clear-token-state": "node downloader.js clear-token-state"
  },
  "keywords": [
    "mapbox",
    "tiles",
    "download",
    "pbf",
    "nodejs"
  ],
  "author": "XXX",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "undici": "^6.21.2"
  }
}
