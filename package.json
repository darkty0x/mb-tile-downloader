{
  "name": "mapbox-downloader",
  "version": "1.0.0",
  "description": "Cross-platform production tile downloader with row-level resume and provider configs.",
  "main": "downloader.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "test:smoke": "node --test --test-concurrency=1 tests/cli-smoke.test.js",
    "download": "node --env-file-if-exists=.env scripts/watchdog.js -- node downloader.js",
    "validate": "node --env-file-if-exists=.env downloader.js --validate",
    "download:mapbox-pbf": "node --env-file-if-exists=.env scripts/watchdog.js -- node downloader.js configs/mapbox-pbf.config.json",
    "download:esri-satellite": "node --env-file-if-exists=.env scripts/watchdog.js -- node downloader.js configs/esri-satellite.config.json",
    "download:mapbox-satellite": "node --env-file-if-exists=.env scripts/watchdog.js -- node downloader.js configs/mapbox-satellite.config.json",
    "download:mapbox-dem": "node --env-file-if-exists=.env scripts/watchdog.js -- node downloader.js configs/mapbox-dem.config.json",
    "split": "node --env-file-if-exists=.env downloader.js split",
    "zip": "node --env-file-if-exists=.env scripts/watchdog.js -- node zip-maker.js",
    "upload": "node --env-file-if-exists=.env scripts/install-storj-uplink.js --if-missing && node --env-file-if-exists=.env scripts/watchdog.js -- node storj-uploader.js",
    "storj-upload": "node --env-file-if-exists=.env scripts/install-storj-uplink.js --if-missing && node --env-file-if-exists=.env scripts/watchdog.js -- node storj-uploader.js",
    "storj-download": "node --env-file-if-exists=.env scripts/install-storj-uplink.js --if-missing && node --env-file-if-exists=.env storj-downloader.js",
    "agent": "node --env-file-if-exists=.env src/agent/agent.js",
    "dashboard": "node --env-file-if-exists=.env dashboard/src/server/app.js",
    "unzip-ranges": "node --env-file-if-exists=.env unzip-ranges.js",
    "delete-unavailable": "node --env-file-if-exists=.env downloader.js delete-unavailable",
    "upload:install-uplink": "node --env-file-if-exists=.env scripts/install-storj-uplink.js",
    "make-directories": "node --env-file-if-exists=.env directory-maker.js",
    "download:mapbox-pbf-splits": "node --env-file-if-exists=.env scripts/watchdog.js -- node downloader.js configs/mapbox-pbf-cig.config.json configs/mapbox-pbf-cmi.config.json configs/mapbox-pbf-kuh.config.json configs/mapbox-pbf-kyj.config.json configs/mapbox-pbf-mcs.config.json configs/mapbox-pbf-rhc.config.json",
    "clear-token-state": "node --env-file-if-exists=.env downloader.js clear-token-state"
  },
  "keywords": [
    "mapbox",
    "tiles",
    "download",
    "pbf",
    "nodejs"
  ],
  "author": "XXX",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "jpeg-js": "^0.4.4",
    "undici": "^6.21.2"
  }
}
